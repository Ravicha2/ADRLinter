# Copy this file to .env and adjust values as needed.

# Neo4j credentials
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# Neo4j memory settings (source of truth for all modules)
NEO4J_HEAP_INITIAL=256m
NEO4J_HEAP_MAX=2048m
NEO4J_PAGECACHE=512m

# LangExtract (ADR constraint extraction) settings
LANDEXTRACT_MODEL_ID=gemma4:31b-cloud
# Use http://host.docker.internal:11434 inside Docker, http://localhost:11434 for local dev
LANDEXTRACT_MODEL_URL=http://host.docker.internal:11434
LANDEXTRACT_JUDGE_MODEL_ID=qwen3.5:cloud
OLLAMA_API_KEY=
