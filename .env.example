# Copy this file to .env and adjust values as needed.

# Neo4j credentials
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# Neo4j memory settings (source of truth for all modules)
NEO4J_HEAP_INITIAL=256m
NEO4J_HEAP_MAX=2048m
NEO4J_PAGECACHE=512m

# LangExtract (ADR constraint extraction) settings
LANGEXTRACT_MODEL_ID=google/gemini-3.1-flash-lite
# OpenRouter API endpoint (OpenAI-compatible)
LANGEXTRACT_MODEL_URL=https://openrouter.ai/api/v1
LANGEXTRACT_PROVIDER=openai
LANGEXTRACT_JUDGE_MODEL_ID=google/gemma-4-26b-a4b-it:free
OPENROUTER_API_KEY=
